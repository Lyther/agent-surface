# agent-surface canonical AI-tool ignore baseline (gitignore syntax).
# Rendered per target as .cursorignore / .kilocodeignore / .clineignore.
# Keeps secrets and high-noise paths out of AI indexing and context.
# Targets already exclude .git and lockfiles; this adds the cross-tool
# baseline. "!" re-includes a path on targets that support negation.

# Secrets and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
**/credentials.json
**/secrets.*
**/service-account*.json
.netrc
id_rsa
id_ed25519

# Dependencies and virtual environments
node_modules/
vendor/
.venv/
venv/
__pycache__/

# Build and generated output
dist/
build/
target/
out/
coverage/
*.min.js
*.map

# Local scratch and agent-surface internals
.agent-surface/
*.log
tmp/
.cache/
