{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-surface target capabilities",
  "type": "object",
  "required": [
    "targets"
  ],
  "properties": {
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "mcp",
          "skills"
        ],
        "properties": {
          "mcp": {
            "$ref": "#/$defs/capability"
          },
          "skills": {
            "$ref": "#/$defs/capability"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "status",
        "locations",
        "distribution",
        "verified_by",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "native",
            "native-experimental",
            "workflow-alias",
            "manual",
            "unsupported",
            "unknown"
          ]
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "distribution": {
          "enum": [
            "generated",
            "local-wired",
            "manual-only",
            "not-applicable"
          ]
        },
        "verified_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
