{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-surface target capabilities",
  "type": "object",
  "required": [
    "targets"
  ],
  "properties": {
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "mcp",
          "skills",
          "subagents"
        ],
        "properties": {
          "mcp": {
            "$ref": "#/$defs/capability"
          },
          "skills": {
            "$ref": "#/$defs/capability"
          },
          "subagents": {
            "$ref": "#/$defs/subagentsCapability"
          },
          "ignores": {
            "$ref": "#/$defs/capability"
          },
          "hooks": {
            "$ref": "#/$defs/capability"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": [
        "status",
        "locations",
        "distribution",
        "verified_by",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "native",
            "native-experimental",
            "workflow-alias",
            "manual",
            "unsupported",
            "unknown"
          ]
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "distribution": {
          "enum": [
            "generated",
            "local-wired",
            "manual-only",
            "not-applicable"
          ]
        },
        "verified_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "subagentsCapability": {
      "type": "object",
      "required": [
        "status",
        "mechanisms",
        "launch_shapes",
        "isolation",
        "headless_supported",
        "distribution",
        "verified_by",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "native",
            "native-experimental",
            "manual",
            "unsupported",
            "unknown"
          ]
        },
        "mechanisms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "agent-tool",
              "agent-team",
              "at-mention",
              "background-agent",
              "dynamic-workflow",
              "native-subagent-tool",
              "task-tool",
              "none",
              "unknown"
            ]
          }
        },
        "launch_shapes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "isolation": {
          "enum": [
            "session",
            "worktree",
            "process",
            "ide-managed",
            "none",
            "unknown"
          ]
        },
        "headless_supported": {
          "type": "boolean"
        },
        "distribution": {
          "enum": [
            "generated",
            "local-wired",
            "manual-only",
            "not-applicable"
          ]
        },
        "verified_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "native",
                  "native-experimental",
                  "manual"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "mechanisms": {
                "not": {
                  "contains": {
                    "enum": [
                      "none",
                      "unknown"
                    ]
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
