{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-surface.local/schemas/workflow.patch.schema.json",
  "title": "agent-surface workflow patch manifest",
  "type": "object",
  "$defs": {
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,80}$"
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "gitHash": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "task_id",
    "filescope",
    "pre_tree_hash",
    "started_at",
    "status"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "ended",
              "verified"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "post_tree_hash",
          "patch_ref",
          "patch_hash",
          "name_status_ref",
          "changed_files",
          "completed_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "verified"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "applies_cleanly",
          "verified_at"
        ],
        "properties": {
          "applies_cleanly": {
            "const": true
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "workflow.patch.v1"
    },
    "run_id": {
      "$ref": "#/$defs/safeId"
    },
    "round_id": {
      "type": "integer",
      "minimum": 0
    },
    "task_id": {
      "$ref": "#/$defs/safeId"
    },
    "filescope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/safePath"
      }
    },
    "pre_tree_hash": {
      "$ref": "#/$defs/gitHash"
    },
    "pre_head": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "post_tree_hash": {
      "$ref": "#/$defs/gitHash"
    },
    "patch_ref": {
      "$ref": "#/$defs/safePath"
    },
    "patch_hash": {
      "$ref": "#/$defs/hash"
    },
    "name_status_ref": {
      "$ref": "#/$defs/safePath"
    },
    "changed_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/safePath"
      }
    },
    "applies_cleanly": {
      "type": "boolean"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "begun",
        "ended",
        "verified"
      ]
    }
  },
  "additionalProperties": false
}
