{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-surface targets",
  "type": "object",
  "required": [
    "in_scope",
    "planned",
    "out_of_scope"
  ],
  "properties": {
    "in_scope": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "status",
          "build_supported",
          "install_supported",
          "renders"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "implemented",
              "planned",
              "deprecated"
            ]
          },
          "build_supported": {
            "type": "boolean"
          },
          "install_supported": {
            "type": "boolean"
          },
          "renders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "planned": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
