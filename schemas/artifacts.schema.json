{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-surface artifacts registry",
  "type": "object",
  "required": [
    "source_types",
    "canonical_command_rule"
  ],
  "properties": {
    "source_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "rules",
          "commands",
          "skills",
          "subagents",
          "hooks",
          "mcps",
          "settings",
          "ignores",
          "plugins",
          "schemas"
        ]
      }
    },
    "canonical_command_rule": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
