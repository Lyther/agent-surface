{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-surface optional external services",
  "type": "object",
  "required": [
    "services"
  ],
  "properties": {
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "status",
          "kind",
          "optional",
          "local_wiring",
          "notes"
        ],
        "properties": {
          "status": {
            "enum": [
              "required",
              "optional",
              "optional-caution"
            ]
          },
          "source_url": {
            "type": "string",
            "pattern": "^https://github\\.com/[^/]+/[^/]+$"
          },
          "path": {
            "type": "string",
            "pattern": "^external/[A-Za-z0-9._-]+$"
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "kind": {
            "enum": [
              "mcp",
              "skill-pack",
              "behavior-pack",
              "source-pack"
            ]
          },
          "optional": {
            "type": "boolean"
          },
          "first_party": {
            "type": "boolean"
          },
          "skill_roots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^external/[A-Za-z0-9._*/-]+$"
            }
          },
          "served_by": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          },
          "mcp": {
            "type": "object",
            "required": [
              "server",
              "validation_hint"
            ],
            "properties": {
              "server": {
                "type": "object",
                "required": [
                  "type",
                  "command",
                  "args"
                ],
                "properties": {
                  "type": {
                    "const": "stdio"
                  },
                  "command": {
                    "type": "string",
                    "minLength": 1
                  },
                  "args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              },
              "validation_hint": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "local_wiring": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "required"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "optional": {
                  "const": false
                }
              }
            },
            "else": {
              "properties": {
                "optional": {
                  "const": true
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "mcp"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "mcp"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "enum": [
                    "skill-pack",
                    "behavior-pack"
                  ]
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "skill_roots"
              ]
            }
          },
          {
            "if": {
              "not": {
                "properties": {
                  "first_party": {
                    "const": true
                  }
                },
                "required": [
                  "first_party"
                ]
              }
            },
            "then": {
              "required": [
                "source_url",
                "path",
                "commit"
              ]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
