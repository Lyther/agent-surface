{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-surface.local/schemas/workflow.worker.schema.json",
  "title": "agent-surface workflow worker artifact",
  "type": "object",
  "$defs": {
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,80}$"
    },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "gitTreeHash": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "verification": {
      "type": "object",
      "required": [
        "cmd",
        "class",
        "exit_code"
      ],
      "properties": {
        "cmd": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "class": {
          "enum": [
            "read_only",
            "build_test",
            "network",
            "filesystem_destructive",
            "deployment",
            "database_mutation"
          ]
        },
        "cwd": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "exit_code": {
          "type": "integer"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "tree_hash": {
          "$ref": "#/$defs/gitTreeHash"
        },
        "stdout_ref": {
          "$ref": "#/$defs/safePath"
        },
        "stdout_hash": {
          "$ref": "#/$defs/hash"
        },
        "stderr_ref": {
          "$ref": "#/$defs/safePath"
        },
        "stderr_hash": {
          "$ref": "#/$defs/hash"
        },
        "redaction": {
          "enum": [
            "none",
            "applied"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "worker",
    "tasks_processed",
    "stop_reason",
    "workflow"
  ],
  "properties": {
    "schema_version": {
      "const": "workflow.v3"
    },
    "run_id": {
      "$ref": "#/$defs/safeId"
    },
    "round_id": {
      "type": "integer",
      "minimum": 0
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "worker": {
      "enum": [
        "dev-feature",
        "dev-fix",
        "dev-chore",
        "dev-refactor"
      ]
    },
    "tasks_processed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "status",
          "files_changed",
          "evidence_refs"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "PASS"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "name_status_ref",
                "patch_ref",
                "patch_hash",
                "pre_tree_hash",
                "post_tree_hash",
                "applies_cleanly"
              ],
              "properties": {
                "applies_cleanly": {
                  "const": true
                }
              }
            }
          }
        ],
        "properties": {
          "task_id": {
            "$ref": "#/$defs/safeId"
          },
          "status": {
            "enum": [
              "PASS",
              "BLOCKED",
              "DEFERRED"
            ]
          },
          "files_changed": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/safePath"
            }
          },
          "summary": {
            "type": "string"
          },
          "name_status_ref": {
            "$ref": "#/$defs/safePath"
          },
          "patch_ref": {
            "$ref": "#/$defs/safePath"
          },
          "patch_hash": {
            "$ref": "#/$defs/hash"
          },
          "pre_tree_hash": {
            "$ref": "#/$defs/gitTreeHash"
          },
          "post_tree_hash": {
            "$ref": "#/$defs/gitTreeHash"
          },
          "applies_cleanly": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/safePath"
            }
          },
          "verify_results": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/verification"
            }
          },
          "self_audit": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "check",
                "result"
              ],
              "properties": {
                "check": {
                  "type": "string",
                  "minLength": 1
                },
                "result": {
                  "enum": [
                    "pass",
                    "fail",
                    "not_run"
                  ]
                },
                "note": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "decisions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "known_limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "user_visible_behavior_changed": {
            "type": "boolean"
          },
          "contracts_touched": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/safePath"
            }
          },
          "blocker": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "detail",
                  "needs"
                ],
                "properties": {
                  "type": {
                    "enum": [
                      "missing_context",
                      "ambiguous_spec",
                      "failing_verify",
                      "dependency_unmet",
                      "external_blocker",
                      "unsafe_command",
                      "schema_invalid",
                      "dirty_worktree",
                      "tool_timeout",
                      "flaky_test",
                      "permission_denied",
                      "repeated_failure"
                    ]
                  },
                  "detail": {
                    "type": "string",
                    "minLength": 1
                  },
                  "needs": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "behavior_preservation": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "boolean",
                "string",
                "number",
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "reason"
        ],
        "properties": {
          "task_id": {
            "$ref": "#/$defs/safeId"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "remaining": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/safeId"
      }
    },
    "stop_reason": {
      "enum": [
        "blocker",
        "context_pressure",
        "queue_empty",
        "drift_check",
        "max_tasks_cap"
      ]
    },
    "stop_detail": {
      "type": "string"
    },
    "workflow": {
      "type": "object",
      "required": [
        "dir",
        "file",
        "owner",
        "run_id",
        "round_id",
        "next_command"
      ],
      "properties": {
        "dir": {
          "$ref": "#/$defs/safePath"
        },
        "file": {
          "const": "worker.json"
        },
        "owner": {
          "enum": [
            "dev-feature",
            "dev-fix",
            "dev-chore",
            "dev-refactor"
          ]
        },
        "next_command": {
          "const": "workflow-reviewer"
        },
        "run_id": {
          "$ref": "#/$defs/safeId"
        },
        "round_id": {
          "type": "integer",
          "minimum": 0
        },
        "parent_artifact_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hash"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
