{
  "name": "grimoire-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only MCP that serves large Agent-Skill packs just-in-time from a self-contained node:sqlite FTS5 index, so the model selects a skill instead of drowning in a startup catalog.",
  "license": "MIT",
  "bin": {
    "grimoire-server": "dist/src/server.js",
    "grimoire-index": "dist/src/indexer.js"
  },
  "scripts": {
    "prebuild": "node require-node.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pretest": "node require-node.mjs",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": ">=1.24.0 <2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "~22.17",
    "typescript": "~5.6"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
